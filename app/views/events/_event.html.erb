<div id="<%= dom_id event %>" class="bg-white shadow-md rounded-lg p-6 mb-4 border border-gray-200">
  <h2 class="text-xl font-semibold text-gray-800 mb-2"><%= event.name %></h2>

  <p class="text-gray-600 mb-1">
    📅 <span class="font-medium">Date:</span> <%= event.date %>
  </p>

  <p class="text-gray-600 mb-1">
    📍 <span class="font-medium">Location:</span> <%= event.location %>
  </p>

  <p class="text-gray-700 mt-3">
    <span class="font-medium">Description:</span><br>
    <%= event.description %>
  </p>
</div>